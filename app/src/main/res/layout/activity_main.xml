<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/buttonScan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Start Scanning"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/labelMinEarnings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Minimum Earnings per Minute:"
        app:layout_constraintTop_toBottomOf="@id/buttonScan"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"/>

    <EditText
        android:id="@+id/editTextMinEarnings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="e.g., 200"
        android:inputType="numberDecimal"
        app:layout_constraintTop_toBottomOf="@id/labelMinEarnings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/labelMaxDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Maximum Trip Distance (km):"
        app:layout_constraintTop_toBottomOf="@id/editTextMinEarnings"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <EditText
        android:id="@+id/editTextMaxDistance"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="e.g., 10"
        android:inputType="number"
        app:layout_constraintTop_toBottomOf="@id/labelMaxDistance"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/textViewResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Result: N/A"
        android:textAppearance="@style/TextAppearance.AppCompat.Large"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/editTextMaxDistance"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/textViewHourlyEarnings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Estimated Hourly: N/A"
        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/textViewResult"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
