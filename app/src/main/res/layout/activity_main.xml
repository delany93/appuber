<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textViewTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Uber Profitability Analyzer"
        android:textSize="20sp"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/button_toggle_overlay_permission"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Request Overlay Permission &amp; Test" />

    <Button
        android:id="@+id/button_show_profitable_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Show Profitable Overlay"
        android:visibility="gone" />

    <Button
        android:id="@+id/button_show_not_profitable_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Show Not Profitable Overlay"
        android:visibility="gone" />
    <Button
        android:id="@+id/button_hide_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Hide Overlay"
        android:visibility="gone" />

    <Button
        android:id="@+id/button_open_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/button_open_settings" />

    <!-- Temporary UI for testing TextParserUtil -->
    <EditText
        android:id="@+id/edittext_test_parse_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="Enter text to parse (e.g., $10.50, 5.2 km, 15 min)"
        android:inputType="textMultiLine"
        android:minLines="2"/>

    <Button
        android:id="@+id/button_test_parse"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Test Text Parser"/>

    <TextView
        android:id="@+id/textview_test_parse_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Parser Result: "
        android:visibility="gone"/>

</LinearLayout>
